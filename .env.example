# Docker compose UID/GID mapping (set for your host user)
UID=1000
GID=1000

# Where the notes repo is mounted inside the container
NOTES_ROOT=/notes_repo/notes
PORT=4567

# MCP runtime modes
MCP_POLICY_MODE=allow_all
MCP_RETRIEVAL_MODE=lexical
MCP_SEMANTIC_PROVIDER_ENABLED=false
MCP_SEMANTIC_PROVIDER=openai
MCP_SEMANTIC_INGESTION_ENABLED=false

# OpenAI semantic retrieval config
MCP_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
MCP_OPENAI_VECTOR_STORE_ID=some_id
